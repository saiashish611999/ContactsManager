@model CountryResponse

@{
    ViewBag.Title = "Delete Country";
}

<h2>Delete Country</h2>

<div class="card mt-3">
    <div class="card-body">

        <h5 class="text-danger">Are you sure you want to delete this country?</h5>

        <hr />

        <div class="mb-3">
            <strong>Name:</strong>
            @Model.CountryName
        </div>

        <div class="mb-3">
            <strong>Id:</strong>
            @Model.CountryId
        </div>

        <form asp-controller="Countries" asp-action="DeleteConfirmed" asp-route-countryId="@Model.CountryId" method="post">

            <button type="submit" class="btn btn-danger">
                Delete
            </button>

            <a asp-action="Index" class="btn btn-secondary">
                Cancel
            </a>

        </form>

    </div>
</div>